# Django Core Settings
SECRET_KEY=replace-with-a-secure-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Gmail SMTP Settings (For alert notifications)
# If empty, Django falls back to local console email output
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# NetWatch API Key Settings (For incoming traffic ingestion authentication)
NETWATCH_API_KEY=nw-capstone-2026-secret-key
